[Unit]
Description=football-predict — Manager of the month Telegram post
After=docker.service network-online.target
Wants=network-online.target

[Service]
Type=oneshot
WorkingDirectory=/opt/football-predict
EnvironmentFile=/opt/football-predict/.env
ExecStart=/usr/bin/docker compose exec -T api python scripts/post_manager_of_month.py
User=root
