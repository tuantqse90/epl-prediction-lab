# Copy to `.env` (same dir as docker-compose.yml) and fill in.
# `.env` is read automatically by `docker compose`.

# --- Postgres ---
POSTGRES_DB=epl
POSTGRES_USER=epl
POSTGRES_PASSWORD=change-me

# --- LLM ---
# Qwen via DashScope (LiteLLM: dashscope/qwen-turbo)
DASHSCOPE_API_KEY=sk-...
ANTHROPIC_API_KEY=

# --- Optional data sources ---
API_FOOTBALL_KEY=
# The Odds API — https://the-odds-api.com (free 500 req/month). Optional; used
# by scripts/ingest_live_odds.py for upcoming-fixture odds.
THE_ODDS_API_KEY=

# --- Telegram bot (optional, for weekly picks channel) ---
# Create bot at @BotFather, add it to your channel as admin with post rights.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Host port bindings (override if colliding with other stacks on shared VPS) ---
API_HOST_PORT=8500
WEB_HOST_PORT=3500
